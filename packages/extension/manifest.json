{
  "manifest_version": 3,
  "name": "Banger",
  "version": "0.0.1",
  "description": "AI-powered meme replies for X.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Banger settings"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/service-worker/index.ts",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.anthropic.com https://api.openai.com https://generativelanguage.googleapis.com https://banger.magician.wtf"
  },
  "externally_connectable": {
    "matches": ["https://banger.magician.wtf/*"]
  },
  "commands": {
    "open-popover": {
      "suggested_key": { "default": "Ctrl+Shift+B", "mac": "Command+Shift+B" },
      "description": "Open Banger suggestions"
    }
  }
}
